# Copy this file to .env and fill in your own values.

# Her-Ashtra-API base URL — local dev, or your Render deployment URL.
EXPO_PUBLIC_API_URL=http://localhost:4000

EXPO_PUBLIC_ENV=dev
EXPO_ROUTER_APP_ROOT=app

# Cloudinary — direct video upload for SOS evidence (unsigned upload preset).
# Leave blank to run SOS without media (location-only alerts still work).
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
